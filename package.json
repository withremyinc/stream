{
  "name": "@withremyinc/stream",
  "version": "1.0.0",
  "description": "Composable Web Streams utilities with streaming JSON and XML parsing.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE.md",
    "NOTICES.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "streams",
    "web-streams",
    "readablestream",
    "transformstream",
    "async-iterable",
    "json",
    "jsonc",
    "xml",
    "parser",
    "llm"
  ],
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "bench:geojson": "pnpm run build && node scripts/bench-geojson.mjs",
    "bench:xml": "pnpm run build && node scripts/bench-xml.mjs",
    "pi": "pi",
    "prepublishOnly": "npm run build"
  },
  "author": "Michael Bullington <michael@withremy.com>",
  "license": "MIT",
  "packageManager": "pnpm@10.8.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/withremyinc/stream.git"
  },
  "homepage": "https://github.com/withremyinc/stream#readme",
  "bugs": {
    "url": "https://github.com/withremyinc/stream/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "tsdown": "^0.21.7",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
